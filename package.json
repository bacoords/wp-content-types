{
	"name": "wp-content-types",
	"version": "0.1.4",
	"description": "A content modeling system for WordPress.",
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"lint:js": "wp-scripts lint-js src/",
		"lint:css": "wp-scripts lint-style 'src/**/*.css'",
		"lint:php": "composer lint",
		"prepare": "husky"
	},
	"devDependencies": {
		"@wordpress/scripts": "^28.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.0.0",
		"@wordpress/components": "^28.0.0",
		"@wordpress/core-data": "^7.0.0",
		"@wordpress/dataviews": "^14.1.0",
		"@wordpress/element": "^6.0.0",
		"@wordpress/i18n": "^5.0.0",
		"@wordpress/icons": "^12.2.0",
		"@wordpress/interface": "^9.29.0",
		"@wordpress/keyboard-shortcuts": "^5.44.0"
	},
	"lint-staged": {
		"*.js": "wp-scripts lint-js",
		"*.css": "wp-scripts lint-style",
		"*.php": "vendor/bin/phpcs"
	}
}
